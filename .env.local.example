# Required: Anthropic API key for Claude
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Override base URL (needed if ANTHROPIC_BASE_URL is set in system env without /v1)
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# Optional: Set to 'false' to use live Nansen API (requires credits)
DEMO_MODE=true

# Optional: Nansen API key (only needed when DEMO_MODE=false)
NANSEN_API_KEY=
